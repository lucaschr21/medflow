{
  "name": "medflow",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "eslint --config tools/quality/eslint.config.mjs .",
    "lint:fix": "eslint --config tools/quality/eslint.config.mjs . --fix",
    "stylelint": "stylelint --config tools/quality/stylelint.config.cjs --ignore-path tools/quality/.stylelintignore \"src/main/webapp/**/*.{scss,css}\"",
    "stylelint:fix": "stylelint --config tools/quality/stylelint.config.cjs --ignore-path tools/quality/.stylelintignore \"src/main/webapp/**/*.{scss,css}\" --fix",
    "format": "prettier . --write --config tools/quality/.prettierrc --ignore-path tools/quality/.prettierignore",
    "format:check": "prettier . --check --config tools/quality/.prettierrc --ignore-path tools/quality/.prettierignore",
    "quality": "npm run lint && npm run stylelint && npm run format:check",
    "prepare": "husky"
  },
  "private": true,
  "packageManager": "npm@11.12.0",
  "dependencies": {
    "@angular/common": "^21.2.3",
    "@angular/compiler": "^21.2.3",
    "@angular/core": "^21.2.3",
    "@angular/forms": "^21.2.3",
    "@angular/platform-browser": "^21.2.3",
    "@angular/router": "^21.2.3",
    "@primeuix/themes": "^2.0.3",
    "@tailwindcss/postcss": "^4.2.2",
    "postcss": "^8.5.8",
    "primeng": "^21.1.3",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.3",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "angular-eslint": "^21.3.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "stylelint": "^17.5.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.0.8"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs,html}": [
      "eslint --config tools/quality/eslint.config.mjs --fix",
      "prettier --write --config tools/quality/.prettierrc --ignore-path tools/quality/.prettierignore"
    ],
    "*.{scss,css}": [
      "stylelint --config tools/quality/stylelint.config.cjs --ignore-path tools/quality/.stylelintignore --fix",
      "prettier --write --config tools/quality/.prettierrc --ignore-path tools/quality/.prettierignore"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write --config tools/quality/.prettierrc --ignore-path tools/quality/.prettierignore"
    ]
  }
}
